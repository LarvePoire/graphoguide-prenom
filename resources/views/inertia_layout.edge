<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title inertia>
      Prénom à tracer — GraphoGuide
    </title>
    <meta
      name="description"
      content="Générez une fiche d'écriture pour apprendre à tracer un prénom : chaque lettre est faite de flèches colorées qui montrent l'ordre et le sens des traits. À imprimer gratuitement."
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700&family=Fredoka:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    @viteReactRefresh()
    @vite(['inertia/app.tsx'])
    @inertiaHead()
    @stack('dumper')
  </head>

  <body>
    @inertia()
  </body>

</html>
